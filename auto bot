import pandas as pd
import numpy as np
import yfinance as yf
import time


# Settings
SYMBOL = "BTC-USD"
FAST_MA = 20
SLOW_MA = 50
RSI_PERIOD = 14


def get_data():
    """Download market data with error handling."""
    try:
        data = yf.download(SYMBOL, period="1d", interval="1m", auto_adjust=True, progress=False)
        if data.empty:
            raise ValueError("No data returned from yfinance.")
        # Flatten MultiIndex columns if present (yfinance v0.2+)
        if isinstance(data.columns, pd.MultiIndex):
            data.columns = data.columns.get_level_values(0)
        return data
    except Exception as e:
        print(f"[ERROR] Failed to fetch data: {e}")
        return None


def calculate_rsi(data, period=RSI_PERIOD):
    """Calculate RSI indicator."""
    close = data['Close'].squeeze()  # Ensure it's a Series, not DataFrame
    delta = close.diff()

    gain = delta.where(delta > 0, 0.0).rolling(window=period).mean()
    loss = (-delta.where(delta < 0, 0.0)).rolling(window=period).mean()

    # Avoid division by zero
    rs = gain / loss.replace(0, np.nan)
    rsi = 100 - (100 / (1 + rs))

    return rsi


def generate_signals(data):
    """Generate BUY, SELL, or HOLD signal."""
    if len(data) < SLOW_MA:
        print(f"[WARNING] Not enough data points ({len(data)}) for SLOW_MA ({SLOW_MA}). Returning HOLD.")
        return "HOLD"

    close = data['Close'].squeeze()  # Ensure Series

    data = data.copy()  # Avoid SettingWithCopyWarning
    data['fast_ma'] = close.rolling(FAST_MA).mean()
    data['slow_ma'] = close.rolling(SLOW_MA).mean()
    data['RSI'] = calculate_rsi(data)

    latest = data.iloc[-1]

    fast = latest['fast_ma']
    slow = latest['slow_ma']
    rsi  = latest['RSI']

    # Guard against NaN values
    if pd.isna(fast) or pd.isna(slow) or pd.isna(rsi):
        print("[WARNING] NaN values detected in indicators. Returning HOLD.")
        return "HOLD"

    if fast > slow and rsi < 70:
        return "BUY"
    elif fast < slow and rsi > 30:
        return "SELL"
    else:
        return "HOLD"


def trading_bot():
    """Main trading loop."""
    print(f"[INFO] Starting trading bot for {SYMBOL}...")
    print(f"[INFO] Fast MA: {FAST_MA} | Slow MA: {SLOW_MA} | RSI Period: {RSI_PERIOD}")

    while True:
        try:
            print(f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] Fetching data...")
            data = get_data()

            if data is None:
                print("[WARNING] Skipping this cycle due to data fetch failure.")
                time.sleep(60)
                continue

            signal = generate_signals(data)
            print(f"Signal: {signal}")

            if signal == "BUY":
                print("[ACTION] Buying asset")
            elif signal == "SELL":
                print("[ACTION] Selling asset")
            else:
                print("[ACTION] Holding — no trade executed.")

        except Exception as e:
            print(f"[ERROR] Unexpected error in trading loop: {e}")

        time.sleep(60)


if __name__ == "__main__":
    trading_bot()